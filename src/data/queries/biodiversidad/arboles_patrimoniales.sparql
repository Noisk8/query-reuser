SELECT DISTINCT ?tree ?treeLabel ?typeLabel WHERE {
  VALUES ?type {
    wd:Q5739210   # árbol patrimonial
    wd:Q811534    # árbol singular
  }

  ?tree wdt:P31 ?type;
        wdt:P17 wd:${COUNTRY_ID}. # CAMBIAR ESTO CON EL "Q" DEL PAÍS

  SERVICE wikibase:label {
    bd:serviceParam wikibase:language "es,en".
  }
}
ORDER BY ?treeLabel