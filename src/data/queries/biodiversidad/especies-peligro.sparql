SELECT DISTINCT ?species ?speciesLabel ?image ?population ?category
WHERE {
  ?species wdt:P225 ?scientificName;
           wdt:P183 wd:${COUNTRY_ID};
           wdt:P141 ?conservationStatus.
  OPTIONAL { ?species wdt:P18 ?image. }
  OPTIONAL { ?species wdt:P1082 ?population. }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "es,en". }
  VALUES ?conservationStatus {
    wd:Q219127
    wd:Q219128
    wd:Q219129
    wd:Q752298
  }
}
ORDER BY ?speciesLabel
LIMIT 100